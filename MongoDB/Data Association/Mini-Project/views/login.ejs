<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10">
        <h3 class="text-3xl text-white mb-5">Log in Your Account</h3>
        <form action="/login" method="POST" class="flex flex-col gap-5 w-full md:w-1/2">
            <input class="border-2 border-white text-white px-3 py-3 outline-none bg-transparent rounded-md" type="email" placeholder="email" name="email">
            <input class="border-2 border-white text-white px-3 py-3 outline-none bg-transparent rounded-md" type="password" placeholder="password" name="password">
            <input class="border-2 border-white text-white px-3 py-3 outline-none bg-transparent rounded-md" type="submit" value="Log in your account">
            
        </form>

    </div>
    
</body>
</html>