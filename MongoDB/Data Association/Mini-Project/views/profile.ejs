<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="bg-zinc-900 text-white w-full min-h-screen bg-zinc-900 p-10">
      <div class="mb-6 flex justify-end w-full">
        <a
          class="text-white bg-red-500 rounded-md w-18 px-3 py-2 mb-10"
          href="/logout"
          >Logout</a
        >
      </div>
      <h3 class="text-3xl">Hello <%= user.name %></h3>
      <h5>You can create your New post</h5>
      <form method="post" action="/post">
        <textarea
          placeholder="What's in your mind"
          class="resize-none p-3 block border-2 border-zinc-800 mb-4 w-1/3 rounded-md" name="content"
        ></textarea>
        <input
          class="px-2 py-2 rounded-md w-40 outline -none bg-blue-500 mb-10"
          type="submit"
        />
      </form>
      <div class="posts">
        <h2 class="text-zinc-500 mb-5">Your Posts</h2>
        <div class="postcontainer flex flex-col gap-5">
          <div
            class="post mb-2 rounded-[5px] w-1/3 bg-zinc-800 border-[1px] border-zinc-800"
          >
            <h4 class="text-blue-500">@username</h4>
            <p class="text-sm">
              Lorem ipsum, dolor sit amet consectetur adipisicing elit. Porro
              veritatis cum corrupti inventore ipsum asperiores tempore dolore
              mollitia qui aperiam sit magni distinctio odio modi, obcaecati
              minima est adipisci sapiente!
            </p>
            <div class="btns flex mt-5 gap-5">
              <a href="" class="text-blue-500">Like</a>
              <a href="" class="text-zinc-600">Edit</a>
            </div>
          </div>
          <div
            class="post mb-2 rounded-[5px] w-1/3 bg-zinc-800 border-[1px] border-zinc-800"
          >
            <h4 class="text-blue-500">@username</h4>
            <p class="text-sm">
              Lorem ipsum, dolor sit amet consectetur adipisicing elit. Porro
              veritatis cum corrupti inventore ipsum asperiores tempore dolore
              mollitia qui aperiam sit magni distinctio odio modi, obcaecati
              minima est adipisci sapiente!
            </p>
            <div class="btns flex mt-5 gap-5">
              <a href="" class="text-blue-500">Like</a>
              <a href="" class="text-zinc-600">Edit</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
