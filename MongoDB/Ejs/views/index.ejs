<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheet/style.css">
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
   <div class="w-full h-full bg-zinc-900 p-10 text-white">
      <div class="nav">
         <a class="text-blue-500 hover:text-blue-300" href="/read">Read Users</a>
      </div>
      <h1 class="text-3xl tracking tighter mb-3">Create user</h1>
     <form action="/create" method="POST" class="flex gap-3">
        <input class="px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg" name="name" type="text" placeholder="name">
        <input class="px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg" name="email" type="text" placeholder="e-mail">
        <input class="px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg" name="image" type="text" placeholder="image-url">
        <input class="px-5 py-2 bg-blue-500 rounded-lg ml-3" name="submit" type="Submit" value="Create User">
     </form>
   </div>
    
</body>
</html>