<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Users</title>

    <link rel="stylesheet" href="/stylesheet/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
<div class="w-full min-h-screen bg-zinc-900 p-10 text-white">

    <a class="text-blue-500 hover:text-blue-300" href="/">Back to Home</a>

    <h1 class="text-3xl tracking-tighter mb-6">All Users</h1>

    <div class="users flex gap-5 flex-wrap">

        <% users.forEach(function(user){ %>

        <div class="user w-72 p-4 bg-zinc-800 rounded-lg">

            <!-- User Image -->
            <img 
                class="w-full h-52 object-cover rounded-lg"
                src="<%= user.image %>" 
                alt="user image"
            >

            <!-- User Name -->
            <h3 class="mt-3 text-xl tracking-tighter">
                <%= user.name %>
            </h3>

            <!-- User Email -->
            <h5 class="text-zinc-500">
                <%= user.email %>
            </h5>

            <!-- Buttons -->
            <div class="flex gap-3 mt-6">
                <a class="text-zinc-200 hover:text-white" href="">
                    Edit User
                </a>

                <a class="text-red-500 hover:text-red-400" href="/delete/<%=user._id%>">
                    Delete User
                </a>
            </div>

        </div>

        <% }) %>

    </div>

</div>
</body>
</html>